# Groq API Key for AI Chatbot
# Get your free API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Redis URL for caching and rate limiting
# Format: redis://username:password@host:port
REDIS_URL=your_redis_url_here

# JWT Secret for authentication (REQUIRED - minimum 32 characters)
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_minimum_32_characters_here

# Admin Credentials (REQUIRED)
ADMIN_USERNAME=admin

# Admin Password Hash (REQUIRED)
# Generate using: node scripts/hash-password.js YourSecurePassword123!
# Password requirements:
# - Minimum 12 characters
# - At least one uppercase letter
# - At least one lowercase letter
# - At least one number
# - At least one special character
# IMPORTANT: Escape $ characters with backslashes for shell compatibility
# Example: ADMIN_PASSWORD_HASH=\$2b\$12\$abcdefghijklmnopqrstuvwxyz
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here_with_escaped_dollar_signs

# Optional: Allowed CORS origins (comma-separated)
# Example: ALLOWED_ORIGINS=https://example.com,https://app.example.com
# ALLOWED_ORIGINS=

# Optional: Enable/disable rate limiting (default: true)
# Set to 'false' only for local development/testing
# ENABLE_RATE_LIMITING=true

# Environment
NODE_ENV=development
